# ==========================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local)
# ==========================================
# These variables are bundled into the client and visible to end users.
# Only include PUBLIC configuration and non-secret values here.

# Supabase Configuration (REQUIRED)
# Get these values from your Supabase project dashboard: https://app.supabase.com/

# Your Supabase project URL (public, safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (public, safe to expose to browsers)
# This key has limited permissions defined by Supabase RLS policies
VITE_SUPABASE_ANON_KEY=pk_anon_xxxxx

# ==========================================
# SERVER-SIDE ONLY - DO NOT USE VITE_ HERE
# ==========================================
# These secrets should NEVER be set in VITE_ env variables
# They will be exposed in client builds and compromise security
# Instead, store these in your server environment (not in repo):

# Server Secret: Supabase service role key (NEVER COMMIT or set as VITE_)
# Store only on your backend server in a secret manager
# DO NOT set: VITE_SUPABASE_SERVICE_ROLE_KEY
# INSTEAD, set server env: SUPABASE_SERVICE_ROLE_KEY

# Server Secret: Claude/LLM API key (NEVER COMMIT or set as VITE_)
# Store only on your backend server in a secret manager
# The /api/llm endpoint will use this securely
# DO NOT set: VITE_CLAUDE_API_KEY
# INSTEAD, set server env: CLAUDE_API_KEY

# Server Secret: hCaptcha secret key (NEVER COMMIT or set as VITE_)
# Store only on your backend server in a secret manager
# The /api/verify-hcaptcha endpoint will use this securely
# DO NOT set: VITE_HCAPTCHA_SECRET_KEY
# INSTEAD, set server env: HCAPTCHA_SECRET

# ==========================================
# PROXY CONFIGURATION
# ==========================================
# Shared token between frontend and server proxies (non-secret, but sensitive)
# Set this to the same value on your server (INTERNAL_API_KEY env var)
# This token authenticates frontend calls to /api/llm and /api/verify-hcaptcha

VITE_INTERNAL_API_KEY=your_internal_api_key_here

# ==========================================
# NOTES
# ==========================================
# 1. Never commit .env.local to git (add to .gitignore)
# 2. All VITE_ variables are embedded in client bundles
# 3. Server secrets (Claude, hCaptcha, service-role keys) belong in server env only
# 4. See api/README.md for server proxy deployment instructions

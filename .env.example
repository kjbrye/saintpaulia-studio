# Supabase Configuration
# Get these values from your Supabase project dashboard: https://app.supabase.com/

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase public anon key (safe to use in client-side code)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service role key (KEEP SECRET - only use for admin operations)
# This is optional but recommended for certain admin features
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# hCaptcha Configuration (optional)
# Get your secret key from https://dashboard.hcaptcha.com/
VITE_HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key_here

# Claude Haiku LLM Configuration (optional)
# Set to true to enable Claude Haiku 4.5 for LLM-powered features
# Requires VITE_CLAUDE_API_KEY to be set for real API calls
VITE_CLAUDE_HAIKU=false
VITE_CLAUDE_MODEL=claude-haiku-4.5
VITE_CLAUDE_API_KEY=sk-ant-...

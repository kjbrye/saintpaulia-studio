# Supabase Configuration
# Get these values from your Supabase project dashboard: https://app.supabase.com/

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase public anon key (safe to use in client-side code)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service role key (KEEP SECRET - only use for admin operations)
# This is optional but recommended for certain admin features
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
